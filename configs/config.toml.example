[gateway]
log_filter = "info"

[feishu]
app_id = "cli_xxx"
app_secret = "replace-with-your-feishu-app-secret"
verification_token = ""
encrypt_key = ""
base_url = "https://open.feishu.cn"
group_only_mentioned = true

[llm]
base_url = "https://api.openai.com/v1"
api_key = "replace-with-your-api-key"
model = "gpt-4.1-mini"
temperature = 0.2
system_prompt = "You are CloudAgent running inside Feishu. Give concise, practical answers in Chinese unless the user asks otherwise."
